# Worker runtime env. Copy to .env only for local shell usage.

DAGENT_WORKER_API_TOKEN=replace-with-generated-worker-token
DAGENT_WORKER_HMAC_SECRET=
DAGENT_WORKER_CONFIG=worker/config.yml
DAGENT_DATA_DIR=.data/worker
DAGENT_WORKER_URL=http://127.0.0.1:8765

# Optional ntfy integration.
NTFY_URL=http://127.0.0.1:8080
NTFY_TOPIC=dagent
# Or multiple topics:
# NTFY_TOPICS=dagent,dagent-phone
NTFY_TOKEN=replace-with-ntfy-token
