# Copy to docker/automation-stack/.env and fill real values.

POSTGRES_IMAGE_TAG=16-alpine
REDIS_IMAGE_TAG=7-alpine
N8N_IMAGE_TAG=latest
CLOUDFLARED_IMAGE_TAG=latest

POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=replace-with-long-random-secret

N8N_ENCRYPTION_KEY=replace-with-32-plus-random-chars
N8N_USER_MANAGEMENT_JWT_SECRET=replace-with-long-random-secret

N8N_PORT=5678
# For a purely local clone, leave these as localhost/http.
# For Cloudflare, set N8N_HOST=n8n.your-domain.example and protocol/URLs to https.
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_EDITOR_BASE_URL=http://localhost:5678/

N8N_WORKER_CONCURRENCY=5
N8N_GRACEFUL_SHUTDOWN_TIMEOUT=60
OFFLOAD_MANUAL_EXECUTIONS_TO_WORKERS=true
QUEUE_HEALTH_CHECK_ACTIVE=true
N8N_METRICS=true
N8N_DIAGNOSTICS_ENABLED=false
N8N_BLOCK_ENV_ACCESS_IN_NODE=false

# n8n calls this worker URL from inside Docker.
DAGENT_WORKER_URL=http://host.docker.internal:8765
DAGENT_WORKER_API_TOKEN=replace-with-dagent-worker-token
DAGENT_CHATGPT_WORKER_URL=http://host.docker.internal:8767
DAGENT_CHATGPT_WORKER_API_TOKEN=replace-with-dagent-chatgpt-worker-token
DAGENT_SHORTCUT_SECRET=replace-with-long-random-secret
CF_ACCESS_CLIENT_ID=replace-with-cloudflare-access-client-id
CF_ACCESS_CLIENT_SECRET=replace-with-cloudflare-access-client-secret

# Optional profile:
# docker compose --profile tunnel ...
CLOUDFLARE_TUNNEL_TOKEN=replace-with-cloudflare-tunnel-token
