# Stored per worker at:
# ~/.config/dagent/workers/<name>.env
#
# The dagentctl script creates this file for you. Keep it chmod 600.

DAGENT_WORKER_HOST=127.0.0.1
DAGENT_WORKER_PORT=8765
DAGENT_WORKER_CONFIG=/home/divyesh-nandlal-vishwakarma/Desktop/Divyesh/dAgent/worker/config.yml
DAGENT_WORKER_API_TOKEN=replace-with-generated-token
DAGENT_WORKER_HMAC_SECRET=
DAGENT_DATA_DIR=/home/divyesh-nandlal-vishwakarma/Desktop/Divyesh/dAgent/.data/worker-main

